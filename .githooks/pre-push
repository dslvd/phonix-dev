#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-origin}"
remote_url="${2:-}"

blocked=false

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "${remote_ref:-}" ]] && continue

  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    blocked=true
    break
  fi
done

if [[ "$blocked" == true ]]; then
  echo ""
  echo "[BLOCKED] Push to 'main' is disabled for this repository."
  echo "Remote: $remote_name ${remote_url:+($remote_url)}"
  echo ""
  echo "Use 'dev' instead:" 
  echo "  git push $remote_name HEAD:dev"
  echo ""
  echo "If you are the repo owner and need to update main, use a reviewed PR from dev -> main."
  echo ""
  exit 1
fi

exit 0
